{
  "name": "syncoboard-monorepo",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "bun run --filter \"*\" dev",
    "start": "bun run --filter \"*\" start",
    "start:pm2": "pm2 start ecosystem.config.js",
    "build": "bun run db generate && bun run build:pkgs && bun run build:services && bun run build:apps",
    "build:pkgs": "bun run --filter \"./packages/*\" build",
    "build:apps": "bun run --filter \"./apps/*\" build",
    "build:services": "bun run --filter \"./services/*\" build",
    "clean": "rm -rf apps/*/.next apps/*/dist packages/*/dist services/*/dist",
    "web": "bun --filter web",
    "dashboard": "bun --filter dashboard",
    "tui": "bun --filter tui",
    "api": "bun --filter @syncoboard/api",
    "db": "bun --filter @syncoboard/db",
    "payment": "bun --filter @syncoboard/payment",
    "shared": "bun --filter @syncoboard/shared",
    "types": "bun --filter @syncoboard/types",
    "utils": "bun --filter @syncoboard/utils",
    "cron": "bun --filter @syncoboard/cron",
    "websocket": "bun --filter websocket",
    "lint": "bun run --filter \"*\" lint",
    "format": "bun prettier --write .",
    "check": "bun prettier --check .",
    "test": "export $(cat packages/db/.env.test | xargs) && bun run db push && bun test"
  },
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/peerjs": "^1.1.0",
    "@types/string-similarity": "^4.0.2",
    "dotenv": "^17.4.1",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "react": "18.3.1",
    "tui": "workspace:*"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "ink": "^5.0.0",
    "next-auth": "5.0.0-beta.30",
    "octokit": "^5.0.5",
    "string-similarity": "^4.0.4",
    "tsx": "^4.21.0"
  }
}
